<Window x:Class="MemoryScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Memory Scanner" Height="720" Width="1080" MinHeight="600" MinWidth="900"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Process" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProcessComboBox" Height="30" DisplayMemberPath="DisplayName" />
                <Button Grid.Column="1" Content="Refresh" Margin="8,0,0,0" Padding="18,4" Click="RefreshProcesses_Click" />
                <Button Grid.Column="2" Content="Attach" Margin="8,0,0,0" Padding="18,4" Click="Attach_Click" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Exact value scan" Margin="0,12,0,12" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Value" VerticalAlignment="Center" />
                <TextBox x:Name="ScanValueTextBox" Grid.Column="1" Height="28" Margin="8,0,16,0" VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="2" Text="Type" VerticalAlignment="Center" />
                <ComboBox x:Name="ValueTypeComboBox" Grid.Column="3" Height="28" Margin="8,0,16,0" />
                <Button x:Name="FirstScanButton" Grid.Column="4" Content="First scan" Padding="18,4" Click="FirstScan_Click" />
                <Button x:Name="NextScanButton" Grid.Column="5" Content="Next scan" Margin="8,0,0,0" Padding="18,4" IsEnabled="False" Click="NextScan_Click" />
                <Button x:Name="CancelScanButton" Grid.Column="6" Content="Cancel" HorizontalAlignment="Left" Margin="8,0,0,0" Padding="18,4" IsEnabled="False" Click="CancelScan_Click" />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ScanProgressBar" Height="18" Minimum="0" Maximum="100" />
            <TextBlock x:Name="ScanProgressTextBlock" Grid.Column="1" Margin="12,0,0,0"
                       MinWidth="210" VerticalAlignment="Center" Text="0 addresses found — 0.0%" />
        </Grid>

        <GroupBox Grid.Row="3" Header="Matches" Padding="8">
            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Address" Binding="{Binding AddressText}" Width="220" />
                    <DataGridTextColumn Header="Current value" Binding="{Binding Value}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Grid Grid.Row="4" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="New value" VerticalAlignment="Center" />
            <TextBox x:Name="WriteValueTextBox" Grid.Column="1" Height="28" Margin="8,0,8,0" VerticalContentAlignment="Center" />
            <Button Grid.Column="2" Content="Write selected" Padding="18,4" Click="WriteSelected_Click" />
            <Button Grid.Column="3" Content="Save address" Margin="8,0,0,0" Padding="18,4" Click="SaveAddress_Click" />
            <TextBlock Grid.Column="4" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="DimGray"
                       Text="Only scan processes you own or are authorized to inspect." />
        </Grid>

        <GroupBox Grid.Row="5" Header="Saved addresses" Padding="8">
            <DataGrid x:Name="SavedGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="220" />
                    <DataGridTextColumn Header="Address" Binding="{Binding AddressText}" Width="200" />
                    <DataGridTextColumn Header="Type" Binding="{Binding ValueType}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StatusBar Grid.Row="6" Margin="0,10,0,0">
            <StatusBarItem><TextBlock x:Name="StatusTextBlock" Text="Not attached" /></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
